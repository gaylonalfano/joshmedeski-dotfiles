#!/usr/bin/env bash
# Smart qmd search - re-indexes if vault has changed, then searches

VAULT="$HOME/c/second-brain"
STAMP="$HOME/.cache/qmd/.last-index"
NEEDS_INDEX=false

mkdir -p "$(dirname "$STAMP")"

# Check if any .md files are newer than last index
if [ ! -f "$STAMP" ]; then
  NEEDS_INDEX=true
elif [ -n "$(find "$VAULT" -name '*.md' -newer "$STAMP" -print -quit)" ]; then
  NEEDS_INDEX=true
fi

if [ "$NEEDS_INDEX" = true ]; then
  gum spin --spinner dot --title "Updating vault index..." -- qmd update
  gum spin --spinner dot --title "Embedding documents..." -- qmd embed
  touch "$STAMP"
fi

RESULT=$(gum spin --spinner dot --title "Searching..." -- qmd query "$@" 2>/dev/null) && echo "$RESULT" || {
  echo "Falling back to keyword search (reranking failed)" >&2
  qmd search "$@"
}
