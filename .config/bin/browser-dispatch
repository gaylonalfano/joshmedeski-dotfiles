#!/usr/bin/env bash

# Map GitHub "org/repo" -> local repo directory
declare -A REPO_DIRS=(
  ["Nutiliti/nutiliti"]="$HOME/c/nu"
  ["joshmedeski/sesh"]="$HOME/c/sesh"
)

# Map GitHub "org/repo" -> branch prefix for new worktrees (e.g. "jam" -> "jam/123-1")
declare -A REPO_BRANCH_PREFIXES=(
  ["joshmedeski/sesh"]="jam"
)

# Map GitHub "org/repo" -> sesh setup command to run on new worktree (optional)
declare -A REPO_SETUP_CMDS=(
  ["Nutiliti/nutiliti"]="nu_setup"
)

github_worktree() {
  local org="$1"
  local repo="$2"
  local kind="$3"
  local number="$4"
  local repo_key="$org/$repo"
  local repo_dir="${REPO_DIRS[$repo_key]}"

  if [[ -z "$repo_dir" ]]; then
    echo "No local directory mapped for $repo_key. Add it to REPO_DIRS in $0."
    exit 1
  fi

  local branch_prefix="${REPO_BRANCH_PREFIXES[$repo_key]:-claude}"
  local setup_cmd="${REPO_SETUP_CMDS[$repo_key]}"
  local issue

  if [[ "$kind" == "pull" ]]; then
    issue=$(gh pr view "$number" --repo "$repo_key" --json closingIssuesReferences --jq '.closingIssuesReferences[0].number' 2>/dev/null)
    if [[ -z "$issue" ]]; then
      issue=$(gh pr view "$number" --repo "$repo_key" --json title,body --jq '"\(.title)\n\(.body)"' 2>/dev/null | grep -oE '#[0-9]+' | head -n1 | tr -d '#')
    fi
    if [[ -n "$issue" ]]; then
      echo "PR #$number references issue #$issue"
    else
      issue="$number"
      echo "PR #$number has no issue reference; using PR number"
    fi
  else
    issue="$number"
  fi

  echo "Issue #$issue in $repo_key"

  cd "$repo_dir" || exit 1
  local target="$repo_dir/.wk/$issue"

  if [[ -d "$target" ]]; then
    sesh connect --switch "$target"
  else
    git worktree add ".wk/$issue" -b "$branch_prefix/$issue-1" --no-track origin/main
    cd "$target" || exit 1
    if [[ -n "$setup_cmd" ]]; then
      sesh connect --switch --command "$setup_cmd" .
    else
      sesh connect --switch .
    fi
  fi

  osascript -e 'tell application "WezTerm" to activate'
}

URL=$(osascript -e 'tell application "Helium" to return URL of active tab of front window' 2>/dev/null)
if [[ -z "$URL" ]]; then
  echo "Failed to get URL from Helium browser."
  exit 1
fi

case "$URL" in
  https://github.com/*/*/issues/[0-9]*|https://github.com/*/*/pull/[0-9]*)
    if [[ "$URL" =~ ^https://github\.com/([^/]+)/([^/]+)/(issues|pull)/([0-9]+) ]]; then
      github_worktree "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}" "${BASH_REMATCH[4]}"
    fi
    ;;
  *)
    echo "No action for URL: $URL"
    exit 1
    ;;
esac
